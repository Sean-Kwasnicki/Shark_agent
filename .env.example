AGENT_NAME=Loop
AGENT_MISSION=Research and identify revenue opportunities for the owner's software business. Draft outreach and product experiments for human approval.
ANTHROPIC_API_KEY=
MODEL_PLANNER=claude-sonnet-4-6
MODEL_WORKER=claude-haiku-4-5-20251001
OWNER_TOKEN=change-me-long-random-string
OWNER_EMAIL=
OWNER_DISCORD_WEBHOOK=
BRAVE_API_KEY=
RESEND_API_KEY=
# Must be an address on a domain verified in Resend (e.g. agent@yourverifieddomain.com).
# Email notifications are skipped unless this is set.
RESEND_FROM=
MAX_SINGLE_SPEND_AUTO_USD=0
MAX_DAILY_SPEND_USD=25
MAX_TOTAL_SPEND_USD=100
CYCLE_INTERVAL_MINUTES=60

# --- Moltbook (register once, human completes claim_url via X post) ---
MOLTBOOK_API_KEY=
MOLTBOOK_FEED_PATH=/posts
MOLTBOOK_MIN_MINUTES_BETWEEN_POSTS=35
MOLTBOOK_MAX_COMMENTS_PER_DAY=20
LISTING_SUBMOLT=general

# --- Crossmint NFT minting (staging = free testnet; switch to www deliberately) ---
CROSSMINT_ENV=staging
CROSSMINT_API_KEY=
CROSSMINT_COLLECTION_ID=default
LISTING_IMAGE_URL=

# --- Stripe (use test keys first) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Commerce policy ---
AUTO_PUBLISH=false
MAX_LIVE_LISTINGS=5

# --- Economics governor ---
MONTHLY_INFRA_USD=5.00
DAILY_COST_BUDGET_USD=1.00
HIBERNATE_LOSS_USD=10.00
GROW_NET_USD=10.00
FORCE_CYCLE_EVERY_N=6

# --- 24/7 data collector ---
COLLECTOR_INTERVAL_MINUTES=15
ENGAGEMENT_WINDOW_HOURS=24
SIGNAL_RETENTION_DAYS=30
CB_THRESHOLD=5
CB_COOLDOWN_MINUTES=60
TREND_HALF_LIFE_DAYS=3.0

# --- Learning (v3 logistic Laplace-TS is default; v2 = instant rollback) ---
SALES_LEARNER=v3
PAYMENT_FEE_PCT=0.029
PAYMENT_FEE_FIXED_USD=0.30
